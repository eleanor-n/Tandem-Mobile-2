{
  "expo": {
    "name": "Tandem - Never Go Alone",
    "slug": "tandem",
    "version": "1.0.0",
    "scheme": "tandem",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.thetandemapp.app",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Tandem uses your photo library so you can add a profile photo and share memories in your scrapbook.",
        "NSCameraUsageDescription": "Tandem uses your camera so you can take a profile photo.",
        "NSMicrophoneUsageDescription": "Tandem uses your microphone so you can record voice memo prompts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.thetandemapp.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Tandem to access your camera to record a video response."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Tandem needs camera access for profile verification.",
          "microphonePermission": "Tandem needs microphone access for video prompts."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Tandem needs microphone access for video prompts."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3e1f19ba-7221-4cff-a70e-c918cdda0506"
      }
    },
    "owner": "tandem_never_go_alone"
  }
}
